# =============================================================================
# .env.example — GestionHokkaido Monorepo
# Copiez ce fichier vers .env.local et remplissez chaque valeur.
# NE JAMAIS committer .env.local dans le dépôt Git.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# Obtenez ces valeurs dans : https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------

# URL publique du projet Supabase (exposée côté client)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Clé anonyme publique (exposée côté client, Row Level Security obligatoire)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Clé de rôle de service — NE JAMAIS exposer côté client
# Utilisée côté serveur uniquement (API Routes, Server Actions)
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# -----------------------------------------------------------------------------
# DISCORD — OAuth2 (connexion des utilisateurs via Discord)
# Panel : https://discord.com/developers/applications → OAuth2
# -----------------------------------------------------------------------------

# ID de l'application Discord (public)
DISCORD_CLIENT_ID=<your-discord-client-id>

# Secret OAuth2 — NE JAMAIS exposer côté client
DISCORD_CLIENT_SECRET=<your-discord-client-secret>

# URL de redirection après OAuth2 (doit correspondre à celle déclarée sur Discord)
# En développement : http://localhost:3000/api/auth/callback/discord
NEXTAUTH_URL=http://localhost:3000

# Secret utilisé par NextAuth.js / Auth.js pour signer les sessions
# Générez-en un avec : openssl rand -base64 32
NEXTAUTH_SECRET=<your-nextauth-secret>

# -----------------------------------------------------------------------------
# DISCORD — Bot Serverless (HTTP Interactions / Webhooks)
# Hébergé sur Vercel via /api/interactions (compatible Edge / Node runtime)
# Panel : https://discord.com/developers/applications → Bot
# -----------------------------------------------------------------------------

# Token du bot Discord — NE JAMAIS exposer côté client
DISCORD_BOT_TOKEN=<your-discord-bot-token>

# Clé publique Ed25519 — indispensable pour vérifier les signatures Discord
# Panel : https://discord.com/developers/applications → General Information
DISCORD_PUBLIC_KEY=<your-discord-application-public-key>

# ID du serveur (guild) principal de l'École d'Exorcisme de Hokkaido
# TODO: Remplacer par l'ID du serveur Discord Hokkaido
DISCORD_GUILD_ID=HOKKAIDO_GUILD_ID_HERE

# Identifiant du site (tokyo ou hokkaido) — partitionne la DB
NEXT_PUBLIC_SITE_ID=hokkaido

# -----------------------------------------------------------------------------
# APPLICATION (optionnel / surcharge)
# -----------------------------------------------------------------------------

# Environnement d'exécution : development | staging | production
NODE_ENV=development

# URL publique complète du déploiement (utilisée pour les liens dans les embeds Discord)
# En production Vercel : https://gestion-hokkaido.vercel.app
# Si non défini, le code tente NEXT_PUBLIC_APP_URL puis VERCEL_PROJECT_PRODUCTION_URL puis VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
